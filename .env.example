# ============================================
# Application Configuration
# ============================================

# Demo mode — use local fixtures only (no backend)
NEXT_PUBLIC_DEMO_MODE=true

# Artificial delay for demo API spinners (ms). Leave unset or 0 for Vercel/production speed.
# NEXT_PUBLIC_DEMO_DELAY_MS=400

# Node Environment
NODE_ENV=production

# Application URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost

# ============================================
# Docker Configuration
# ============================================

# Docker Registry (for Jenkins/CI)
DOCKER_REGISTRY=your-registry.com
DOCKER_IMAGE_NAME=nextjs-app

# ============================================
# Database Configuration (if needed)
# ============================================

# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ============================================
# Authentication (if needed)
# ============================================

# JWT_SECRET=your-secret-key-here
# JWT_EXPIRES_IN=7d

# ============================================
# External Services (if needed)
# ============================================

# API_KEY=your-api-key
# EXTERNAL_SERVICE_URL=https://api.example.com

# ============================================
# Monitoring & Analytics (if needed)
# ============================================

# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# Feature Flags (if needed)
# ============================================

# ENABLE_FEATURE_X=true
# ENABLE_FEATURE_Y=false
